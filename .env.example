# ElevenLabs — comma-separated list (TTS + STT)
ELEVENLABS_API_KEYS=sk_aaa,sk_bbb,sk_ccc

# Google Gemini — comma-separated list (rotate on quota errors)
GEMINI_API_KEYS=AIza_xxx,AIza_yyy

# Cloudflare R2 (get from Cloudflare Dashboard → R2 → Manage API Tokens)
CLOUDFLARE_ACCOUNT_ID=abc123def456
CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=videogenerator
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Ayrshare (get from app.ayrshare.com → API Key → connect TikTok account)
AYRSHARE_API_KEY=your_ayrshare_key
